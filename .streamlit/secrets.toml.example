# Copy this file to .streamlit/secrets.toml and fill in your values.
# DO NOT commit secrets.toml to git (it is already gitignored below).
#
# Streamlit Community Cloud users: paste these key/value pairs into the
# "Secrets" panel of your app's settings instead of committing them.
#
# How to get the values:
# 1. Go to https://discord.com/developers/applications and create an app.
# 2. Under "OAuth2 -> Redirects" add EXACTLY your hosted app URL,
#    e.g. https://nefnofap-hmm.streamlit.app  (no trailing slash, no path).
# 3. Copy the application's Client ID and Client Secret.
# 4. In Discord enable Developer Mode (User Settings -> Advanced),
#    then right-click your server icon -> Copy Server ID.

DISCORD_CLIENT_ID = "your_application_id"
DISCORD_CLIENT_SECRET = "your_application_secret"
DISCORD_REDIRECT_URI = "https://your-app.streamlit.app"
DISCORD_GUILD_ID = "your_server_id"

# Optional: where to send users who aren't in the server yet.
# Defaults to https://discord.gg/MSXdaexYdH if omitted.
# DISCORD_INVITE_URL = "https://discord.gg/MSXdaexYdH"
