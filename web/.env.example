# ── Auth.js core ───────────────────────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET=

# In production set this to your deployed origin, e.g. https://regime.yourdomain.com
# On Vercel this is inferred, but setting it explicitly avoids callback issues.
AUTH_URL=http://localhost:3000

# ── Discord OAuth app (https://discord.com/developers/applications) ───────────
# OAuth2 → add redirect: {AUTH_URL}/api/auth/callback/discord
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# ── Gating ────────────────────────────────────────────────────────
# The server users must belong to. Right-click your server → Copy Server ID
# (enable Developer Mode first). Leave blank in local dev to fail OPEN.
DISCORD_GUILD_ID=

# Optional: role id that unlocks tier "premium" (plumbed through for future
# gating; the regime dashboard is open to any guild member today).
DISCORD_PREMIUM_ROLE_ID=
